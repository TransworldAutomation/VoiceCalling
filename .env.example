# Copy this file to ".env" and fill in your keys.
# The dashboard (Layer 1) works even if these are blank.
# You only need them for real calling (Layer 2).

# --- Anthropic (the AI brain + summaries) ---
ANTHROPIC_API_KEY=

# --- Sarvam AI (Indian-language speech-to-text and text-to-speech) ---
SARVAM_API_KEY=

# --- Twilio (the phone calls) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- Your public URL from ngrok (no trailing slash), e.g. https://abcd.ngrok-free.app ---
PUBLIC_URL=
