[Unit]
Description=AI Voice Interview - Dashboard (port 8000)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/Voice-Calling-App
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/ubuntu/Voice-Calling-App/.venv/bin/python -m app.dashboard
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
